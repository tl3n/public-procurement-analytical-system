# Copy to .env before running: cp .env.example .env

# --- PostgreSQL ---
POSTGRES_USER=procurement
POSTGRES_PASSWORD=procurement
POSTGRES_DB=procurement
DATABASE_URL=postgresql+asyncpg://procurement:procurement@postgres:5432/procurement

# --- Redis ---
REDIS_URL=redis://redis:6379/0
# How long aggregation responses stay cached.
CACHE_TTL_SECONDS=60

# --- Prozorro API ---
PROZORRO_API_URL=https://public.api.openprocurement.org/api/2.5

# --- Collector ---
# Interval between incremental sync runs (minutes).
SYNC_INTERVAL_MINUTES=10

# Collection strategy:
#   continuous — walk the feed forward from INITIAL_LOAD_START_TIMESTAMP until
#                MAX_TENDERS records have been processed in this cycle.
#   monthly    — stratified backfill: collect up to MONTHLY_QUOTA records per
#                calendar month starting at MONTHLY_START_YEAR_MONTH. Each
#                cycle advances one or more months until the budget for the
#                cycle is spent; a month is "complete" once its quota is
#                reached or the feed crosses into the next month.
COLLECTION_MODE=continuous

# --- continuous-mode knobs ---
MAX_TENDERS=20000
# Feed offset seed for the first run: Unix timestamp = 2026-01-01 00:00:00 UTC.
INITIAL_LOAD_START_TIMESTAMP=1767225600

# --- monthly-mode knobs (ignored when COLLECTION_MODE=continuous) ---
MONTHLY_QUOTA=2000
MONTHLY_START_YEAR_MONTH=2026-01
# Leave empty to walk up to the current month.
MONTHLY_END_YEAR_MONTH=

# --- Ports ---
BACKEND_PORT=8000
FRONTEND_PORT=5173
