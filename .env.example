# Copy to .env before running: cp .env.example .env

# --- PostgreSQL ---
POSTGRES_USER=procurement
POSTGRES_PASSWORD=procurement
POSTGRES_DB=procurement
DATABASE_URL=postgresql+asyncpg://procurement:procurement@postgres:5432/procurement

# --- Redis ---
REDIS_URL=redis://redis:6379/0
# How long aggregation responses stay cached.
CACHE_TTL_SECONDS=60

# --- Prozorro API ---
PROZORRO_API_URL=https://public.api.openprocurement.org/api/2.5

# --- Collector ---
# Interval between incremental sync runs (minutes).
SYNC_INTERVAL_MINUTES=10
# Hard cap on tenders collected
MAX_TENDERS=20000
# Feed offset seed for the first run: Unix timestamp = 2026-01-01 00:00:00 UTC.
INITIAL_LOAD_START_TIMESTAMP=1767225600

# --- Ports ---
BACKEND_PORT=8000
FRONTEND_PORT=5173
